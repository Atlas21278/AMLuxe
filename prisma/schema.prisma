generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Commande {
  id          Int       @id @default(autoincrement())
  fournisseur String
  date        DateTime  @default(now())
  statut      String    @default("En préparation")
  tracking          String?
  notes             String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
  frais       Frais[]

  @@index([fournisseur])
  @@index([statut])
  @@index([date])
  @@index([deletedAt])
}

model Article {
  id             Int       @id @default(autoincrement())
  marque         String
  modele         String
  prixAchat      Float
  etat           String
  refFournisseur String?
  statut         String    @default("En stock")
  devise         String    @default("EUR")
  prixVente      Float?
  plateforme     String?
  prixVenteReel  Float?
  fraisVente     Float?
  dateVente      DateTime?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  commandeId     Int
  commande       Commande  @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  historique     ArticleHistorique[]

  @@index([marque])
  @@index([statut])
  @@index([commandeId])
  @@index([plateforme])
  @@index([deletedAt])
}

model ArticleHistorique {
  id        Int      @id @default(autoincrement())
  articleId Int
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  champ     String
  ancienne  String?
  nouvelle  String?
  createdAt DateTime @default(now())

  @@index([articleId])
}

model Frais {
  id          Int      @id @default(autoincrement())
  type        String
  montant     Float
  description String?
  createdAt   DateTime @default(now())
  commandeId  Int
  commande    Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model AbonnementMensuel {
  id        Int      @id @default(autoincrement())
  mois      String   @unique // format "YYYY-MM"
  montant   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Audit {
  id        Int      @id @default(autoincrement())
  action    String   // CREATE | UPDATE | DELETE
  ressource String   // commande | article | frais | user
  cible     Int?     // ID de la ressource concernée
  details   String?  // JSON optionnel avec les données modifiées
  userEmail String?
  createdAt DateTime @default(now())

  @@index([ressource])
  @@index([createdAt])
}

model Config {
  id        Int      @id @default(autoincrement())
  cle       String   @unique
  valeur    String
  updatedAt DateTime @updatedAt
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  nom        String
  motDePasse String
  role       String   @default("admin")
  actif      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
