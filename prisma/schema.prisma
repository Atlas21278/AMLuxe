generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Commande {
  id          Int       @id @default(autoincrement())
  fournisseur String
  date        DateTime  @default(now())
  statut      String    @default("En préparation")
  tracking          String?
  trackingData      Json?
  trackingUpdatedAt DateTime?
  notes             String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  articles    Article[]
  frais       Frais[]

  @@index([fournisseur])
  @@index([statut])
  @@index([date])
}

model Article {
  id             Int       @id @default(autoincrement())
  marque         String
  modele         String
  prixAchat      Float
  etat           String
  refFournisseur String?
  statut         String    @default("En stock")
  prixVente      Float?
  plateforme     String?
  prixVenteReel  Float?
  fraisVente     Float?
  dateVente      DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  commandeId     Int
  commande       Commande  @relation(fields: [commandeId], references: [id], onDelete: Cascade)

  @@index([marque])
  @@index([statut])
  @@index([commandeId])
  @@index([plateforme])
}

model Frais {
  id          Int      @id @default(autoincrement())
  type        String
  montant     Float
  description String?
  createdAt   DateTime @default(now())
  commandeId  Int
  commande    Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model AbonnementMensuel {
  id        Int      @id @default(autoincrement())
  mois      String   @unique // format "YYYY-MM"
  montant   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Config {
  id        Int      @id @default(autoincrement())
  cle       String   @unique
  valeur    String
  updatedAt DateTime @updatedAt
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  nom        String
  motDePasse String
  role       String   @default("admin")
  actif      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
