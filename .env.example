# ============================================================
# AMLuxe — Variables d'environnement
# Copiez ce fichier en .env et renseignez vos propres valeurs
# ============================================================

# Base de données PostgreSQL (Railway, Supabase, ou locale)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth — URL publique de l'application
NEXTAUTH_URL="http://localhost:3000"

# NextAuth — clé secrète (générer avec : openssl rand -base64 32)
NEXTAUTH_SECRET="votre-secret-aleatoire-ici"

# TrackingMore API (optionnel — pour le suivi des colis)
# Obtenez une clé sur https://www.trackingmore.com
TRACKINGMORE_API_KEY=""

# Uploadthing — stockage photos articles (https://uploadthing.com)
UPLOADTHING_TOKEN=""
